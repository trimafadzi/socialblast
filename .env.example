# SocialBlast Configuration
# Copy to .env and fill in your credentials

# X/Twitter Account
X_EMAIL=your_email@example.com
X_USERNAME=QuantumFomo
X_PASSWORD=your_p...Settings
POST_INTERVAL_MINUTES=120
MAX_DAILY_POSTS=12
REPLY_ENABLED=false
REPLY_MAX_DAILY=20
NICHE=crypto,tech,AI

# AI (OpenRouter — GRATIS)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Model: google/gemini-2.0-flash-001 (free tier, rate limited)

# Browser
HEADLESS=true
BROWSER_DATA_DIR=./data/browser
